# LLM Provider: 'openai' or 'claude' or 'ollama'
LLM_PROVIDER=ollama

# OpenAI API Key (required for embeddings, optional for chat if using Claude)
OPENAI_API_KEY=your_openai_api_key_here

# Claude API Key (optional, only if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database - Supabase PostgreSQL
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=rgym%d$qjmVxHn6T@MaB*aM%w6Tj1g8
DB_HOST=db.vtljutjljmkipalirdxt.supabase.co
DB_PORT=5432
