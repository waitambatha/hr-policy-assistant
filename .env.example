# LLM Provider: 'openai', 'huggingface', 'cohere', 'claude'
# Note: Embeddings require 'openai', 'huggingface', or 'cohere'
# Claude can be used for chat, but needs one of the above for embeddings
LLM_PROVIDER=openai

# API Keys (at least one embedding provider required)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
COHERE_API_KEY=your_cohere_api_key_here

# Database - Supabase PostgreSQL
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=rgym%d$qjmVxHn6T@MaB*aM%w6Tj1g8
DB_HOST=db.vtljutjljmkipalirdxt.supabase.co
DB_PORT=5432
DB_SCHEMA=hr_rag

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True

# Redis (optional - for caching and rate limiting)
REDIS_URL=redis://127.0.0.1:6379/1

# Celery (optional - set to False to run tasks synchronously)
CELERY_ALWAYS_EAGER=True
CELERY_BROKER_URL=redis://127.0.0.1:6379/0

# Encryption key for API keys (auto-generated if not set)
ENCRYPTION_KEY=gAAAAABmK1234567890abcdefghijklmnopqrstuvwxyz=
